# Configuração Apache — RH Manager
# Garante que actualizações ao código (HTML, JS, CSS) chegam aos utilizadores
# sem dependerem de Ctrl+F5. Imagens e fontes mantêm cache normal.

<IfModule mod_headers.c>
    <FilesMatch "\.(html|js|css)$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# Negar acesso directo a ficheiros sensíveis (config, base de dados, backups, .htaccess)
<FilesMatch "(^\.htaccess|\.sqlite|\.sqlite-journal|\.sqlite-shm|\.sqlite-wal|\.bak|\.example\.php|config\.php)$">
    Require all denied
</FilesMatch>
